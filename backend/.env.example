# Copy this file to .env and fill in the values. Never commit .env.

# Runtime
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database (Neon Postgres). Leave blank locally to boot without a DB (/health -> db:false).
DATABASE_URL=

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# External football data (API-Football v3)
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
# Requests/minute your plan allows (free ~10, paid much higher). Keeps us under 429.
API_FOOTBALL_RPM=10

# Protects /admin/sync/* endpoints when triggered from outside (cron-job.org etc.)
SYNC_SECRET=change-me

# Platform admins (the app owner). Comma-separated emails that get the /admin
# panel and can promote other admins. Set this to YOUR account email before
# going live, or nobody can reach the admin panel.
ADMIN_EMAILS=

# CORS: comma-separated allowed origins, or * for any (dev only). In production
# set this to your frontend origin, e.g. https://extratime.vercel.app
CORS_ORIGIN=*
